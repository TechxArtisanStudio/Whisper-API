# Whisper model location (project root .env)
# Copy to .env and adjust paths.

# Server port (default: 9876). Used by run.sh
# PORT=9876

# Directory containing base.pt, large-v3.pt, etc. (default: models/ at project root)
# WHISPER_MODEL_ROOT=/path/to/models

# Per-model override: full path to .pt file (overrides MODEL_ROOT for that model)
# WHISPER_MODEL_BASE=/path/to/base.pt
# WHISPER_MODEL_LARGE_V3=/path/to/large-v3.pt
